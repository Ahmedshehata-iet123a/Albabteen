<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

   <form string="Insurance Brokerage" create="0" delete="0">
                  <header>
                    <field name="state" widget="statusbar" nolabel="1"/>
                  </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="policy_no" readonly="1"/>
                                <field name="id_no" readonly="1"/>
                                <field name="sponsor_no" readonly="1"/>
                                <field name="sponsor_name" readonly="1"/>
                                <field name="user_id" readonly="1"/>
                                <field name="cinv_id" readonly="1"/>
                                <field name="vinv_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="date_doc" readonly="1"/>
                                <field name="doc_state" readonly="1"/>
                                <field name="list_price" readonly="1"/>
                                <field name="profit_amount" readonly="1"/>
                                <field name="standard_price" readonly="1"/>
                                <button name="action_done" string="Validate" class="oe_highlight" type="object" attrs="{'readonly':[('state','!=','draft')]}" states="draft"/>
                            </group>
                        </group>

                    </sheet>
                </form>
        <tree string="Insurance Brokerage" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'">
                    <field name="policy_no"/>
                    <field name="id_no"/>
                    <field name="sponsor_no"/>
                    <field name="sponsor_name"/>
                    <field name="user_id"/>
                    <field name="date_doc"/>
                    <field name="doc_state"/>
                    <field name="list_price"/>
                    <field name="profit_amount"/>
                    <field name="standard_price"/>
                    <field name="state"/>
                </tree>

    </data>
</odoo>