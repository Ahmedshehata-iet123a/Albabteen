<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="insurrance_conf_view_tree" model="ir.ui.view">
            <field name="name">insurrance_conf_view_tree</field>
            <field name="model">insurrance.conf</field>
            <field name="arch" type="xml">
                <tree string="_tree" create="0" editable="top">
                    <field name="journal_id" required="1"/>
                    <field name="debit_account" required="1"/>
                    <field name="credit_account" required="1"/>
                    <field name="online_journal_id" required="1"/>
                    <field name="type" force_save="1" readonly="1"/>
                </tree>
            </field>
        </record>
        <record id="ins_Configuration_action" model="ir.actions.act_window">
            <field name="name">Configuration</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">insurrance.conf</field>
            <field name="view_mode">tree</field>
        </record>
         <menuitem id="insurance_brokerage_menu_parent_conf" name="Configuration"
              parent="insurance_brokerage_menu_root" action="ins_Configuration_action" sequence="5"/>
    </data>
</odoo>