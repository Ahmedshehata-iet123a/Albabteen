<odoo>
    <record id="partner_ledger_view_form" model="ir.ui.view">
        <field name="name">partner_ledger_view_form</field>
        <field name="model">partner.ledger.customer</field>
        <field name="arch" type="xml">
            <form string="_form">
                <sheet>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="partner_id" widget="many2many_tags"/>

                    </group>
                    <footer>
                        <button name="print_excel" string="get Data" type="object"/>

                        or
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <record id="partner_ledger_report_action" model="ir.actions.act_window">
        <field name="name">Partner Ledger</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">partner.ledger.customer</field>
        <field name="view_mode">tree,form</field>
        <field name="target">new</field>
        <field name="view_id" ref="partner_ledger_view_form"/>
    </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="menu_partner_ledger_report" name="Partner Ledger" parent="account_accountant.menu_accounting"
                  action="partner_ledger_report_action" sequence="50"/>

</odoo>