                                            <!--                                            </tr>-->
                                            <tr>
                                                <td class="text-left">Vat Number</td>
                                                <td class="text-center">
                                                    <span t-field="company.vat"/>
                                                </td>
                                                <td class="text-right arabic">ضريبة القيمة المضافة</td>
                                            </tr>
                                            <!--                                            <tr>-->
                                            <!--                                                <td class="text-left">Other Seller Id</td>-->
                                            <!--                                                <td class="text-center">-->
                                            <!--                                                    &lt;!&ndash;                                                    <span t-field="company.other_seller_id"/>&ndash;&gt;-->
                                            <!--                                                </td>-->
                                            <!--                                                <td class="text-right arabic">معرف أخر</td>-->
                                            <!--                                            </tr>-->
                                        </table>
                                    </div>

                                    <div class="col-6" style="margin-left:5px">
                                        <table style="border:1pt solid black;width:100%;"
                                               class="table table-bordered table-sm">
                                            <tr style="border:1pt solid black;width:100%;color:black;">
                                                <td width="25%" style="font-weight: bold;background-color:#DCDCDC;">
                                                    Buyer
                                                </td>
                                                <td width="50%"
                                                    style="font-weight: bold;text-align:center;background-color:#DCDCDC;"></td>
                                                <td width="25%" class="text-right arabic"
                                                    style="font-weight: bold;text-align:center;background-color:#DCDCDC;">
                                                    المشتري
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="text-left">Name</td>
                                                <td class="text-center">
                                                    <span t-field="o.partner_id.name"/>
                                                    <br/>
                                                    <span t-field="o.partner_id.arabic_name"/>
                                                </td>
                                                <td class="text-right arabic">الاسم</td>
                                            </tr>

                                            <tr>
                                                <td class="text-left">Street Name</td>
                                                <td class="text-center">
                                                    <span t-field="o.partner_id.street"/>
                                                    <br/>
                                                    <span t-field="o.partner_id.arabic_address"/>
                                                </td>
                                                <td class="text-right arabic">اسم الشارع</td>
                                            </tr>
                                            <tr>
                                                <td class="text-left">District</td>
                                                <td class="text-center">
                                                    <span t-field="o.partner_id.state_id.name"/>
                                                    <br/>
                                                    <span t-field="o.partner_id.arabic_state"/>
                                                </td>
                                                <td class="text-right arabic">الحي</td>
                                            </tr>
                                            <tr>
                                                <td class="text-left">City</td>
                                                <td class="text-center">
                                                    <span t-field="o.partner_id.city"/>
                                                    <br/>
                                                    <span t-field="o.partner_id.arabic_city"/>
                                                </td>
                                                <td class="text-right arabic">المدينة</td>
                                            </tr>
                                            <tr>
                                                <td class="text-left">Country</td>
                                                <td class="text-center">
                                                    <span t-field="o.partner_id.country_id.name"/>
                                                    <br/>
                                                    <span t-field="o.partner_id.arabic_country"/>
                                                </td>
                                                <td class="text-right arabic" style="width:18%;">البلد</td>
                                            </tr>
                                            <tr>
                                                <td class="text-left">Postal Code</td>
                                                <td class="text-center">
                                                    <span t-field="o.partner_id.zip"/>
                                                </td>
                                                <td class="text-right arabic">الرمز البريدي</td>
                                            </tr>
                                            <!--                                            <tr>-->
                                            <!--                                                <td class="text-left">Additional No</td>-->
                                            <!--                                                <td class="text-center">-->
                                            <!--                                                    &lt;!&ndash;                                                    <span t-field="o.partner_id.additional_no"/>&ndash;&gt;-->
                                            <!--                                                </td>-->
                                            <!--                                                <td class="text-right arabic">الرقم الاضافي للعنوان</td>-->
                                            <!--                                            </tr>-->
                                            <tr>
                                                <td class="text-left">Vat Number</td>
                                                <td class="text-center">
                                                    <span t-field="o.partner_id.vat"/>
                                                </td>
                                                <td class="text-right arabic">ضريبة القيمة المضافة</td>
                                            </tr>
                                            <!--                                            <tr>-->
                                            <!--                                                <td class="text-left">Other Seller Id</td>-->
                                            <!--                                                <td class="text-center">-->
                                            <!--                                                    &lt;!&ndash;                                                    <span t-field="o.partner_id.other_seller_id"/>&ndash;&gt;-->
                                            <!--                                                </td>-->
                                            <!--                                                <td class="text-right arabic">معرف أخر</td>-->
                                            <!--                                            </tr>-->
                                        </table>
                                    </div>
                                </div>

                                <br/>

                                <table style="border:1pt solid grey;width:100%;color:black; margin-top:-10pt; color:black;"
                                       class="table-condensed">
                                    <thead>
                                        <tr>
                                            <td width="20%" style="font-weight: bold;background-color:#DCDCDC;">Line
                                                Items
                                            </td>
                                            <td colspan="6" style="font-weight: bold;background-color:#DCDCDC;"/>
                                            <td width="20%" style="font-weight: bold;background-color:#DCDCDC;"
                                                class="text-right arabic">التفاصيل
                                            </td>
                                        </tr>

                                        <tr style="background-color:#DCDCDC">
                                            <td width="25%"
                                                style="border:1pt solid grey;text-align:center;padding:2pt; ">Nature
                                                of
                                                goods
                                                <br/>
                                                or services
                                                <br/>
                                                <span class="arabic">تفاصيل السلع أو الخدمات</span>
                                            </td>
                                            <td style="border:1pt solid grey;text-align:center;padding:2pt;">Unit
                                                Price
                                                <br/>
                                                <span class="arabic">سعر الوحدة</span>
                                            </td>
                                            <td style="border:1pt solid grey;text-align:center;padding:2pt;width:7%">
                                                Quantity
                                                <br/>
                                                <span class="arabic">الكمية</span>
                                            </td>
                                            <td style="border:1pt solid grey;text-align:center;padding:2pt;">Taxable
                                                <br/>
                                                Amount
                                                <br/>
                                                <span class="arabic">المبلغ الخاضع للضريبة</span>
                                            </td>
                                            <td style="border:1pt solid grey;text-align:center; width:10%;padding:2pt">
                                                Discount
                                                <br/>
                                                <span class="arabic">خصومات</span>
                                            </td>
                                            <td style="border:1pt solid grey;text-align:center;padding:2pt;width:8%">
                                                Tax
                                                Rate
                                                <br/>
                                                <span class="arabic">نسبة الضريبة</span>
                                            </td>
                                            <td style="border:1pt solid grey;text-align:center; width:10%;padding:2pt">
                                                Tax Amount
                                                <br/>
                                                <span class="arabic">مبلغ الضريبة</span>
                                            </td>
                                            <td style="border:1pt solid grey;text-align:center;padding:2pt;">Item
                                                Subtotal<br/>(Including VAT)
                                                <br/>
                                                <span class="arabic">المجموع (شامل ضريبة القيمة المضافة)</span>
                                            </td>
                                        </tr>
                                    </thead>
                                    <t t-set="tax_total" t-value="0"/>
                                    <t t-set="discount_total" t-value="0"/>
                                    <tbody class="invoice_tbody">
                                        <tr t-foreach="o.invoice_line_ids" t-as="l">
                                            <t t-set="line_tax_total" t-value="0"/>
                                            <t t-foreach="l.tax_ids" t-as="t">
                                                <t t-set="tax_total"
                                                   t-value="tax_total + l.price_subtotal* t.amount/100"/>
                                                <t t-set="line_tax_total" t-value="line_tax_total + t.amount"/>
                                            </t>
                                            <t t-set="discount_total"
                                               t-value="discount_total + ((l.price_unit * l.quantity) - l.price_subtotal)"/>
                                            <td style="border-right:1pt solid grey;padding:3pt">
                                                <span t-field="l.name"/>
                                                -
                                                <!--                                                <span class="text-right arabic"-->
                                                <!--                                                      t-esc="doc.get_product_arabic_name(l.product_id.id)"/>-->
                                                <br/>
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt">
                                                <span t-field="l.price_unit"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:center;padding:3pt">
                                                <span t-esc="'%.2f'%(l.quantity)"/>
                                            </td>

                                            <td style="padding:3pt;border-right:1pt solid grey;text-align:right;">
                                                <sapn t-esc="l.price_unit * l.quantity"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>

                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt;">
                                                <span t-field="l.discount"/>
                                                %
                                            </td>

                                            <td style="border-right:1pt solid grey;padding:2pt;text-align:center;">
                                                <t t-foreach="l.tax_ids" t-as="t">
                                                    <span t-esc="'%.2f'%(t.amount)"/>
                                                    %
                                                </t>
                                                <span t-if="not l.tax_ids">0.0 %</span>
                                            </td>
                                            <td style="padding:3pt;border-right:1pt solid grey;text-align:right;">
                                                <t t-set="line_tax_total"
                                                   t-value="l.price_subtotal*line_tax_total/100"/>
                                                <sapn t-esc="line_tax_total"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt">
                                                <span t-field="l.price_total"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <table style="border:1pt solid grey;width:100%;color:black;margin-top:10px; color:black;"
                                       class="table table-bordered table-sm">
                                    <thead>
                                        <tr>
                                            <td width="33%" style="font-weight: bold;background-color:#DCDCDC;">
                                                Total
                                                Amounts
                                            </td>
                                            <td width="47%" style="font-weight: bold;background-color:#DCDCDC;"/>
                                            <td width="20%" style="font-weight: bold;background-color:#DCDCDC;"
                                                class="text-right arabic">المبالغ الإجمالية
                                            </td>
                                        </tr>
                                        <!--                                        <t t-set="discount_before_total" t-value="doc.amount_untaxed + discount_total"/>-->
                                        <tr>
                                            <td class="text-left"
                                                style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">
                                                Total (Excluding VAT)
                                            </td>
                                            <td class="text-right arabic"
                                                style="border-right:1pt solid grey;text-align:right;padding:3pt">
                                                المبلغ
                                                الإجمالي / غير شامل ضريبة المضافة للضريبة
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt"
                                                class="text-right">
                                                <!--                                                <span t-esc="discount_before_total"-->
                                                <!--                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>-->
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-left"
                                                style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">
                                                Discount
                                            </td>
                                            <td class="text-right arabic"
                                                style="border-right:1pt solid grey;text-align:right;padding:3pt">
                                                مجموع
                                                الخصم
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt"
                                                class="text-right">
                                                <span t-esc="discount_total"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-left"
                                                style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">
                                                Total Taxable Amount (Excluding VAT)
                                            </td>
                                            <td class="text-right arabic"
                                                style="border-right:1pt solid grey;text-align:right;padding:3pt">
                                                إجمالي
                                                المبلغ الخاضع للضريبة/ غير شامل ضريبة المضافة للضريبة
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt"
                                                class="text-right">
                                                <span t-esc="o.amount_untaxed"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-left"
                                                style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">
                                                Total VAT
                                            </td>
                                            <td class="text-right arabic"
                                                style="border-right:1pt solid grey;text-align:right;padding:3pt">
                                                إجمالي
                                                ضريبة القيمة المضافة
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt"
                                                class="text-right">
                                                <span t-esc="tax_total"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-left"
                                                style="font-weight: bold;border-right:1pt solid grey;text-align:left;padding:3pt">
                                                Total Amount Due
                                            </td>
                                            <td class="text-right arabic"
                                                style="border-right:1pt solid grey;text-align:right;padding:3pt">
                                                إجمالي
                                                المبلغ المستحق
                                            </td>
                                            <td style="border-right:1pt solid grey;text-align:right;padding:3pt"
                                                class="text-right">
                                                <span t-esc="o.amount_residual"
                                                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                            </td>
                                        </tr>
                                    </thead>
                                </table>
                                <table style="border:1pt solid grey;width:100%;color:black;color:black;"
                                       class="table table-bordered table-sm">
                                    <thead>
                                        <tr>
                                            <td width="30%" style="font-weight: bold;background-color:#DCDCDC;">
                                                AMOUNT
                                                INVOICED
                                            </td>
                                            <td width="70%">
                                                <!--                                                <span t-esc="o.amount_total_words(o.amount_total)"/>-->
                                            </td>
                                        </tr>
                                    </thead>
                                </table>
                                <table style="border:1pt solid grey;width:100%;color:black;color:black; margin-top:0pt;"
                                       class="table table-bordered table-sm">
                                    <thead>
                                        <tr>
                                            <td class="text-right arabic" width="70%" style="padding-right:12px;">
                                                <!--                                                <span t-esc="o.amount_word(o.amount_total)"/>-->
                                            </td>
                                            <td class="text-right arabic" width="30%"
                                                style="font-weight: bold;background-color:#DCDCDC;">المبالغ المفوترة
                                            </td>
                                        </tr>
                                    </thead>
                                </table>

                            </div>
                        </div>
                    </t>
                    <!--                    </div>-->
                </t>

            </t>
