                                                    <br/>
                                                    <span t-field="company.partner_id.arabic_state"/>
                                                </td>
                                                <td class="text-right arabic">الحي</td>
                                            </tr>
                                            <tr>
                                                <td class="text-left">City</td>
                                                <td class="text-center">
                                                    <span t-field="company.partner_id.city"/>
                                                    <br/>
                                                    <span t-field="company.partner_id.arabic_city"/>
                                                </td>
                                                <td class="text-right arabic">المدينة</td>
                                            </tr>
                                            <tr>
                                                <td class="text-left">Country</td>
                                                <td class="text-center" style="width:15%;">
                                                    <span t-field="company.partner_id.country_id.name"/>
                                                    <br/>
                                                    <span t-field="company.partner_id.arabic_country"/>
                                                </td>
                                                <td class="text-right arabic" style="width:18%;">البلد</td>
                                            </tr>
                                            <tr>
