<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Inherit Form View to Modify it -->
        <record id="account_move_form_view_inherit" model="ir.ui.view">
            <field name="name">account.move.form.view.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
<!--                <xpath expr="//field[@name='partner_id']" position="after">-->
<!--                    <field name="third_party"/>-->
<!--                    <field name="waybill_num"/>-->
<!--                </xpath>-->

                <xpath expr="//field[@name='invoice_date']" position="after">
                    <!-- Add your fields or attributes here -->
                    <field name="po_number"
                           attrs="{'invisible': [('move_type', '!=', 'out_invoice')]}"
                    />
<!--                    <field name="sale_id" context="{'default_sale_id':active_id}" readonly="1"/>-->
<!--                    <field name="project_id" readonly="1"/>-->
                </xpath>
                <xpath expr="//field[@name='tax_totals']" position="after">
                    <field name="untaxed_amount" widget="monetary" readonly="1"/>
                    <field name="taxed_amount" widget="monetary" readonly="1"/>
                    <field name="amount_tax" string='Tax Amount' widget="monetary" readonly="1"/>
                    <field name="disc_amount" string='Discount Amount' widget="monetary" readonly="1"/>
                    <field name="total_before_tax" widget="monetary" readonly="1"/>
                    <field name="amount_total" string='Total Amount' readonly="1"/>
                </xpath>
                <xpath expr="//field[@name='tax_totals']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="account_move_tree_view_inherit" model="ir.ui.view">
            <field name="name">account.move.tree.view.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='amount_untaxed_signed']" position="before">
                    <!-- Add new fields here -->
<!--                    <field name="project_id"/>-->
                    <field name="untaxed_amount" sum="Total Untaxed amount"/>
                    <field name="taxed_amount" sum="Total Taxed Amount"/>
                </xpath>

            </field>
        </record>


        <record id="account_move_inherit_bills_tree_view" model="ir.ui.view">
            <field name="name">account.move.inherit.bills.tree.view</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_in_invoice_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='amount_untaxed_signed']" position="before">
                    <!-- Add new fields here -->
<!--                    <field name="project_id"/>-->
                    <field name="untaxed_amount" sum="Total Untaxed amount"/>
                    <field name="taxed_amount" sum="Total Taxed Amount"/>
                </xpath>

            </field>
        </record>
    </data>
</odoo>