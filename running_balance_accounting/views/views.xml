<odoo>
    <!-- Inherit Form View to Modify it -->
    <record id="account_journal_dashboard_kanban_view_running_balance" model="ir.ui.view">
        <field name="name"></field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <xpath expr="//t/div[@id='dashboard_bank_cash_right']/div" position="replace">
                <div class="row">
                    <div id="dashboard_bank_cash_balance" class="col overflow-hidden text-start">
                        <span>Running Balance</span>
                    </div>
                    <div class="col-auto text-end">
                        <span class="o_kanban_monetary">
                            <t t-esc="dashboard.account_balance"/>
                        </span>
                    </div>
                </div>
                <!-- Add your fields or attributes here -->
            </xpath>

        </field>
    </record>
</odoo>